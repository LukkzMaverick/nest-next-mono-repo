{
  "name": "nest-next-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/supabase-types"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/backend",
    "build": "npm run build --workspace=apps/frontend && npm run build --workspace=apps/backend",
    "start": "npm run start:prod --workspace=apps/backend",
    "supabase:up": "docker compose -f docker-compose.supabase.yml up -d",
    "supabase:down": "docker compose -f docker-compose.supabase.yml down",
    "supabase:logs": "docker compose -f docker-compose.supabase.yml logs -f",
    "supabase:gen-types": "npx supabase gen types typescript --db-url postgresql://postgres:postgres@localhost:54322/postgres > packages/supabase-types/src/database.types.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
